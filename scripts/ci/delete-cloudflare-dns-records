#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 2 ]; then
  echo "usage: scripts/ci/delete-cloudflare-dns-records <zone-name> <record-name>" >&2
  exit 64
fi

zone_name="$1"
record_name="$2"
list_page_size=50

if [ -z "${CLOUDFLARE_API_TOKEN:-}" ]; then
  echo "CLOUDFLARE_API_TOKEN is required" >&2
  exit 1
fi

if [ -z "${CLOUDFLARE_DEFAULT_ACCOUNT_ID:-}" ]; then
  echo "CLOUDFLARE_DEFAULT_ACCOUNT_ID is required" >&2
  exit 1
fi

api() {
  local method="$1"
  local path="$2"

  curl -fsS \
    -X "${method}" \
    -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
    -H "Content-Type: application/json" \
    "https://api.cloudflare.com/client/v4/${path}"
}

urlencode() {
  jq -nr --arg value "$1" '$value | @uri'
}

zone_query="zones?account.id=$(urlencode "${CLOUDFLARE_DEFAULT_ACCOUNT_ID}")&name=$(urlencode "${zone_name}")&per_page=${list_page_size}"
zone_id="$(api GET "${zone_query}" | jq -er --arg zone_name "${zone_name}" '.result[] | select(.name == $zone_name) | .id')"

for record_type in A AAAA CNAME; do
  records_query="zones/${zone_id}/dns_records?type=${record_type}&name=$(urlencode "${record_name}")&per_page=${list_page_size}"
  api GET "${records_query}" \
    | jq -r '.result[] | [.id, .type, .name, .content] | @tsv' \
    | while IFS=$'\t' read -r record_id type name content; do
      if [ -z "${record_id}" ]; then
        continue
      fi

      if [ "${type}" = "AAAA" ] && [ "${content}" = "100::" ]; then
        echo "Keeping Cloudflare-managed DNS ${type} ${name} -> ${content}"
        continue
      fi

      echo "Deleting Cloudflare DNS ${type} ${name} -> ${content}"
      api DELETE "zones/${zone_id}/dns_records/${record_id}" >/dev/null
    done
done
