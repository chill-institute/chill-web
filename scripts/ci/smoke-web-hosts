#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 1 ]; then
  echo "usage: scripts/ci/smoke-web-hosts <staging|production|production-app|production-redirects>" >&2
  exit 64
fi

environment="$1"
curl_flags=(
  --fail
  --silent
  --show-error
  --header "Accept: text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
  --header "Accept-Language: en-US,en;q=0.9"
  --user-agent "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36"
  --retry 12
  --retry-delay 5
  --retry-all-errors
)

smoke_production_app() {
  curl "${curl_flags[@]}" "https://${CHILL_PRODUCTION_DOMAIN}/" >/dev/null
}

smoke_production_redirects() {
  for host in "www.${CHILL_PRODUCTION_DOMAIN}" "${BINGE_PRODUCTION_DOMAIN}" "${BINGE_PRODUCTION_REDIRECT_DOMAIN}"; do
    final_url="$(curl "${curl_flags[@]}" --location --output /dev/null --write-out '%{url_effective}' "https://${host}/")"
    case "${final_url}" in
      "https://${CHILL_PRODUCTION_DOMAIN}/"*) ;;
      *)
        echo "Expected https://${host}/ to resolve to https://${CHILL_PRODUCTION_DOMAIN}/, got ${final_url}" >&2
        exit 1
        ;;
    esac
  done
}

case "${environment}" in
  staging)
    curl "${curl_flags[@]}" "https://${CHILL_STAGING_DOMAIN}/" >/dev/null
    ;;

  production)
    smoke_production_app
    smoke_production_redirects
    ;;

  production-app)
    smoke_production_app
    ;;

  production-redirects)
    smoke_production_redirects
    ;;

  *)
    echo "unsupported environment: ${environment}" >&2
    exit 64
    ;;
esac
