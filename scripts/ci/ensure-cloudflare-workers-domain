#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 3 ]; then
  echo "usage: scripts/ci/ensure-cloudflare-workers-domain <zone-name> <hostname> <service-name>" >&2
  exit 64
fi

zone_name="$1"
hostname="$2"
service_name="$3"

if [ -z "${CLOUDFLARE_API_TOKEN:-}" ]; then
  echo "CLOUDFLARE_API_TOKEN is required" >&2
  exit 1
fi

if [ -z "${CLOUDFLARE_DEFAULT_ACCOUNT_ID:-}" ]; then
  echo "CLOUDFLARE_DEFAULT_ACCOUNT_ID is required" >&2
  exit 1
fi

api() {
  local method="$1"
  local path="$2"
  local data="${3:-}"
  local response
  local status

  if [ -n "${data}" ]; then
    response="$(
      curl -sS \
        -w '\n%{http_code}' \
        -X "${method}" \
        -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
        -H "Content-Type: application/json" \
        --data "${data}" \
        "https://api.cloudflare.com/client/v4/${path}"
    )"
  else
    response="$(
      curl -sS \
        -w '\n%{http_code}' \
        -X "${method}" \
        -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
        -H "Content-Type: application/json" \
        "https://api.cloudflare.com/client/v4/${path}"
    )"
  fi

  status="${response##*$'\n'}"
  response="${response%$'\n'*}"

  if [ "${status}" -lt 200 ] || [ "${status}" -ge 300 ]; then
    echo "Cloudflare API ${method} ${path} failed with HTTP ${status}" >&2
    printf '%s\n' "${response}" | jq -r '
      if type == "object" and (.errors // []) != [] then
        .errors[] | "Cloudflare error \(.code): \(.message)"
      else
        .
      end
    ' >&2
    return 1
  fi

  printf '%s\n' "${response}"
}

urlencode() {
  jq -nr --arg value "$1" '$value | @uri'
}

account_id="$(urlencode "${CLOUDFLARE_DEFAULT_ACCOUNT_ID}")"
zone_query="zones?account.id=${account_id}&name=$(urlencode "${zone_name}")&per_page=50"
zone_id="$(api GET "${zone_query}" | jq -er --arg zone_name "${zone_name}" '.result[] | select(.name == $zone_name) | .id')"

payload="$(
  jq -nc \
    --arg hostname "${hostname}" \
    --arg service "${service_name}" \
    --arg zone_id "${zone_id}" \
    '{hostname: $hostname, service: $service, zone_id: $zone_id, environment: "production"}'
)"

api PUT "accounts/${account_id}/workers/domains" "${payload}" \
  | jq -er --arg hostname "${hostname}" --arg service "${service_name}" '
    if .success == true then
      .result | "Ensured Cloudflare Workers domain \(.hostname) -> \(.service)"
    else
      error("Cloudflare Workers domain ensure failed for \($hostname) -> \($service)")
    end
  '
