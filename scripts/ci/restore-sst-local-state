#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 1 ]; then
  echo "usage: scripts/ci/restore-sst-local-state <artifact-prefix>" >&2
  exit 64
fi

artifact_prefix="$1"

if [ -z "${GITHUB_REPOSITORY:-}" ]; then
  echo "GITHUB_REPOSITORY is required" >&2
  exit 1
fi

if [ -z "${GH_TOKEN:-}" ]; then
  echo "GH_TOKEN is required" >&2
  exit 1
fi

artifact_id="$(
  ARTIFACT_PREFIX="${artifact_prefix}" gh api \
    "repos/${GITHUB_REPOSITORY}/actions/artifacts?per_page=100" \
    --jq '.artifacts | map(select(.expired == false and (.name | startswith(env.ARTIFACT_PREFIX)))) | sort_by(.created_at) | reverse | .[0].id // ""'
)"

if [ -z "${artifact_id}" ]; then
  echo "No SST local state artifact found for prefix ${artifact_prefix}; starting fresh"
  exit 0
fi

restore_dir="$(mktemp -d)"
trap 'rm -rf "${restore_dir}"' EXIT

artifact_zip="${restore_dir}/sst-local-state.zip"
gh api "repos/${GITHUB_REPOSITORY}/actions/artifacts/${artifact_id}/zip" > "${artifact_zip}"
unzip -q "${artifact_zip}" -d "${restore_dir}/artifact"

if [ ! -f "${restore_dir}/artifact/sst-local-state.tar.gz" ]; then
  echo "SST local state artifact ${artifact_id} did not contain sst-local-state.tar.gz" >&2
  exit 1
fi

mkdir -p "${restore_dir}/extracted"
tar -xzf "${restore_dir}/artifact/sst-local-state.tar.gz" -C "${restore_dir}/extracted"

if [ ! -d "${restore_dir}/extracted/state" ]; then
  echo "SST local state artifact ${artifact_id} did not contain a state directory" >&2
  exit 1
fi

state_dir="$(scripts/ci/sst-local-state-path)"
rm -rf "${state_dir}"
mkdir -p "${state_dir}"
cp -a "${restore_dir}/extracted/state/." "${state_dir}/"
echo "Restored SST local state artifact ${artifact_id} to ${state_dir}"
