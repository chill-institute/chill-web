#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 3 ]; then
  echo "usage: scripts/ci/detach-cloudflare-pages-domains <project-name> <zone-name> <domain>..." >&2
  exit 64
fi

project_name="$1"
zone_name="$2"
shift 2

list_page_size=50

if [ -z "${CLOUDFLARE_API_TOKEN:-}" ]; then
  echo "CLOUDFLARE_API_TOKEN is required" >&2
  exit 1
fi

if [ -z "${CLOUDFLARE_DEFAULT_ACCOUNT_ID:-}" ]; then
  echo "CLOUDFLARE_DEFAULT_ACCOUNT_ID is required" >&2
  exit 1
fi

if [ "${CONFIRM_CLOUDFLARE_PAGES_DOMAIN_DETACH:-false}" != "true" ]; then
  echo "CONFIRM_CLOUDFLARE_PAGES_DOMAIN_DETACH=true is required" >&2
  exit 1
fi

api() {
  local method="$1"
  local path="$2"
  local response
  local status

  response="$(
    curl -sS \
      -w '\n%{http_code}' \
      -X "${method}" \
      -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
      -H "Content-Type: application/json" \
      "https://api.cloudflare.com/client/v4/${path}"
  )"
  status="${response##*$'\n'}"
  response="${response%$'\n'*}"

  if [ "${status}" -lt 200 ] || [ "${status}" -ge 300 ]; then
    echo "Cloudflare API ${method} ${path} failed with HTTP ${status}" >&2
    printf '%s\n' "${response}" | jq -r '
      if type == "object" and (.errors // []) != [] then
        .errors[] | "Cloudflare error \(.code): \(.message)"
      else
        .
      end
    ' >&2
    return 1
  fi

  printf '%s\n' "${response}"
}

api_delete() {
  local path="$1"

  api DELETE "${path}" >/dev/null
}

api_get() {
  local path="$1"

  api GET "${path}"
}

urlencode() {
  jq -nr --arg value "$1" '$value | @uri'
}

account_id="$(urlencode "${CLOUDFLARE_DEFAULT_ACCOUNT_ID}")"
project="$(urlencode "${project_name}")"
zone_query="zones?account.id=${account_id}&name=$(urlencode "${zone_name}")&per_page=${list_page_size}"
zone_id="$(api_get "${zone_query}" | jq -er --arg zone_name "${zone_name}" '.result[] | select(.name == $zone_name) | .id')"

delete_dns_records() {
  local record_name="$1"

  for record_type in A AAAA CNAME; do
    records_query="zones/${zone_id}/dns_records?type=${record_type}&name=$(urlencode "${record_name}")&per_page=${list_page_size}"
    api_get "${records_query}" \
      | jq -r '.result[] | [.id, .type, .name, .content] | @tsv' \
      | while IFS=$'\t' read -r record_id type name content; do
        if [ -z "${record_id}" ]; then
          continue
        fi

        echo "Deleting Cloudflare DNS ${type} ${name} -> ${content}"
        api_delete "zones/${zone_id}/dns_records/${record_id}"
      done
  done
}

pages_domains="$(api_get "accounts/${account_id}/pages/projects/${project}/domains")"

for domain_name in "$@"; do
  encoded_domain="$(urlencode "${domain_name}")"
  has_pages_domain="$(
    printf '%s\n' "${pages_domains}" \
      | jq -r --arg domain_name "${domain_name}" 'any(.result[]?; .name == $domain_name)'
  )"

  if [ "${has_pages_domain}" = "true" ]; then
    echo "Detaching Cloudflare Pages domain ${domain_name} from ${project_name}"
    api_delete "accounts/${account_id}/pages/projects/${project}/domains/${encoded_domain}"
  else
    echo "Cloudflare Pages domain ${domain_name} is not attached to ${project_name}"
  fi

  delete_dns_records "${domain_name}"
done
