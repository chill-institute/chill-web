#!/usr/bin/env bash
set -euo pipefail

blocked=(
  AWS_ACCESS_KEY_ID
  AWS_SECRET_ACCESS_KEY
  AWS_SESSION_TOKEN
  CLOUDFLARE_API_KEY
  CLOUDFLARE_API_TOKEN
  CLOUDFLARE_DEFAULT_ACCOUNT_ID
  CLOUDFLARE_ACCOUNT_ID
  CF_API_TOKEN
  SST_TOKEN
)

found=0
for name in "${blocked[@]}"; do
  if [ -n "${!name:-}" ]; then
    echo "${name} is unexpectedly present" >&2
    found=1
  fi
done

if [ "${found}" -ne 0 ]; then
  exit 1
fi
