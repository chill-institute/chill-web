#!/usr/bin/env bash
set -euo pipefail

require_env() {
  local name="$1"
  local value="${!name:-}"
  if [ -z "${value}" ]; then
    echo "${name} is required" >&2
    exit 1
  fi
}

require_env CLOUDFLARE_API_TOKEN
require_env CLOUDFLARE_DEFAULT_ACCOUNT_ID
require_env CLOUDFLARE_WORKERS_DOMAIN_HOSTNAME

api_base="https://api.cloudflare.com/client/v4/accounts/${CLOUDFLARE_DEFAULT_ACCOUNT_ID}/workers/domains"
domains_json="$(
  curl --fail-with-body --silent --show-error \
    --header "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
    --header "Content-Type: application/json" \
    "${api_base}"
)"

domain_id="$(
  jq --raw-output \
    --arg hostname "${CLOUDFLARE_WORKERS_DOMAIN_HOSTNAME}" \
    '.result[]? | select(.hostname == $hostname) | .id' \
    <<<"${domains_json}" |
    head -n 1
)"

if [ -z "${domain_id}" ]; then
  echo "No existing Workers custom domain for ${CLOUDFLARE_WORKERS_DOMAIN_HOSTNAME}"
  exit 0
fi

echo "Deleting existing Workers custom domain for ${CLOUDFLARE_WORKERS_DOMAIN_HOSTNAME}"
curl --fail-with-body --silent --show-error \
  --request DELETE \
  --header "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
  --header "Content-Type: application/json" \
  "${api_base}/${domain_id}" >/dev/null
