{
  "name": "@chill-institute/web",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run -r test && vp run -r build",
    "dev": "vp run chill#dev",
    "dev:chill": "vp run chill#dev",
    "dev:binge": "vp run binge#dev",
    "build": "vp run -r build",
    "build:chill": "vp run chill#build",
    "build:binge": "vp run binge#build",
    "preview:chill": "vp run chill#preview",
    "preview:binge": "vp run binge#preview",
    "test": "vp run -r test",
    "test:chill": "vp run chill#test",
    "test:binge": "vp run binge#test",
    "smoke": "vp run chill#smoke && vp run binge#smoke",
    "smoke:chill": "vp run chill#smoke",
    "smoke:binge": "vp run binge#smoke",
    "check": "vp run -r check",
    "check:chill": "vp run chill#check",
    "check:binge": "vp run binge#check",
    "e2e": "vp run chill#e2e && vp run binge#e2e",
    "e2e:chill": "vp run chill#e2e",
    "e2e:binge": "vp run binge#e2e",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "knip": "vp exec knip",
    "verify": "vp lint && vp run -r check && vp run -r test && vp run -r build",
    "verify:chill": "vp lint && vp run chill#check && vp run chill#test && vp run chill#build",
    "verify:binge": "vp lint && vp run binge#check && vp run binge#test && vp run binge#build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "knip": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "packageManager": "pnpm@11.0.3"
}
