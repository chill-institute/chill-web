{
  "name": "@chill-institute/web",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp test && vp build",
    "dev": "vp dev --host 0.0.0.0 --port 58300",
    "build": "vp build",
    "preview": "vp preview --host 0.0.0.0 --port 58300",
    "test": "vp test",
    "check": "vp check && vp exec knip --no-config-hints",
    "smoke": "vp exec playwright test e2e/smoke.spec.ts",
    "e2e": "vp exec playwright test",
    "visual": "vp exec playwright test -c playwright.visual.config.ts",
    "visual:update": "vp exec playwright test -c playwright.visual.config.ts --update-snapshots",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "knip": "vp exec knip --no-config-hints",
    "sst": "sst",
    "verify": "vp run check && vp test && vp build",
    "prepare": "vp config",
    "quality": "vp run verify && vp run e2e && vp run visual"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@bufbuild/protobuf": "^2.12.0",
    "@chill-institute/contracts": "github:chill-institute/chill-contracts#v2.0.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@sentry/react": "^10.53.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "ts-pattern": "^5.9.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@tanstack/router-plugin": "^1.167.35",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "knip": "^6.13.1",
    "sst": "^4.14.1",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.22",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "0.1.22"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "packageManager": "pnpm@11.2.2"
}
