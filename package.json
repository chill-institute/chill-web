{
  "name": "chill-web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev --host 0.0.0.0 --port 3000",
    "build": "vp build",
    "preview": "vp preview --host 0.0.0.0 --port 3000",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "format": "pnpm exec oxfmt src/components src/lib src/routes src/main.tsx src/query-client.ts src/router.tsx src/routeTree.gen.ts vite.config.ts",
    "format:check": "pnpm exec oxfmt --check src/components src/lib src/routes src/main.tsx src/query-client.ts src/router.tsx src/routeTree.gen.ts vite.config.ts",
    "lint": "pnpm exec oxlint --react-plugin --jsx-a11y-plugin --vitest-plugin --deny-warnings . --ignore-pattern 'src/routeTree.gen.ts'",
    "check": "pnpm run format:check && pnpm run lint",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@chill-institute/contracts": "^0.1.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.163.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tanstack/router-plugin": "^1.163.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^27.0.0",
    "knip": "^5.85.0",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
