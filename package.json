{
  "name": "@chill-institute/web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev --host 0.0.0.0 --port 3000",
    "build": "vp build",
    "preview": "vp preview --host 0.0.0.0 --port 3000",
    "knip": "vp exec knip",
    "test": "vp test src --run",
    "verify": "vp check && vp run test && vp run knip && vp build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "check": "vp check",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@bufbuild/protobuf": "^2.11.0",
    "@chill-institute/contracts": "^1.0.1",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.163.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tanstack/router-plugin": "^1.163.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "knip": "^6.0.5",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
